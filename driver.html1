<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CizaFood Driver</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<style>
body{margin:0;background:#0B0B0C;color:#fff;font-family:Inter;}
.header{padding:20px;font-weight:800;font-size:22px;}
.card{background:#151517;margin:10px;padding:14px;border-radius:12px;}
.btn{width:100%;padding:12px;border:none;border-radius:10px;background:#D4AF37;font-weight:800;}
.btn.red{background:#ff4444;color:#fff;}
#map{height:300px;margin:10px;border-radius:12px;}
.status{padding:10px;margin:10px;border-radius:10px;text-align:center;font-weight:700;}
.online{background:#00c853;color:#000;}
.offline{background:#444;}
.timer{color:#D4AF37;font-weight:800;margin-top:5px;}
</style>
</head>

<body>

<div class="header">🚗 Driver App</div>

<div id="statusBox" class="status offline">OFFLINE</div>

<div style="padding:10px;">
<button class="btn" onclick="toggleStatus()">Changer statut</button>
</div>

<div id="orders"></div>

<div id="map"></div>

<script type="module">
  
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getFirestore, collection, onSnapshot, doc, updateDoc, getDocs } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

const app = initializeApp({
apiKey:"AIzaSyA-Dh3VguPXVk27DwOkMjRbYIXEhrEPcsM",
projectId:"cizafood"
});

const db = getFirestore(app);

const driverId = "driver1";

let driverStatus="offline";
let currentOrder=null;
let map, driverMarker;

// STATUS
window.toggleStatus = async function(){
driverStatus = driverStatus==="offline"?"online":"offline";
await updateDoc(doc(db,"drivers",driverId),{status:driverStatus});
renderStatus();
}

function renderStatus(){
statusBox.className="status "+driverStatus;
statusBox.innerText=driverStatus.toUpperCase();
}

// 🔥 LISTENER UBER LEVEL
onSnapshot(collection(db,"orders"),snap=>{

let html="";

snap.forEach(docSnap=>{
let o=docSnap.data();

// 🔥 AUTO EXPIRE OFFER (IMPORTANT)
if(o.status==="searching_driver" && o.offerExpiresAt && Date.now()>o.offerExpiresAt){
retryDispatch(docSnap.id);
}

// 🔥 OFFER
if(o.status==="searching_driver" && o.offerDriverId===driverId){

let timeLeft=Math.max(0,Math.floor((o.offerExpiresAt-Date.now())/1000));

currentOrder={id:docSnap.id,...o};

html+=`
<div class="card">
<b>Nouvelle course</b><br>
${o.total} BIF<br>

<div class="timer">⏳ ${timeLeft}s</div>

<button class="btn" onclick="accept()">Accepter</button>
<button class="btn red" onclick="refuse()">Refuser</button>
</div>
`;
}

// 🔥 ASSIGNED
if(o.status==="assigned" && o.assignedDriverId===driverId){

currentOrder={id:docSnap.id,...o};

html+=`
<div class="card">
<b>Course active</b><br>
${o.total} BIF<br>

<button class="btn" onclick="pick()">Ramasser</button>
<button class="btn red" onclick="deliver()">Livré</button>
</div>
`;
}

});

orders.innerHTML=html;
});

// 🔥 ACCEPT (SÉCURISÉ)
window.accept=async function(){

if(!currentOrder) return;

await updateDoc(doc(db,"orders",currentOrder.id),{
status:"assigned",
assignedDriverId:driverId,
driverName:"Jean",
driverPhone:"+25770000000"
});

await updateDoc(doc(db,"drivers",driverId),{
status:"busy",
currentOrderId:currentOrder.id
});
}

// 🔥 REFUSE → RETRY AUTO
window.refuse=async function(){

await retryDispatch(currentOrder.id);
}

// 🔥 RETRY DISPATCH (UBER CORE)
async function retryDispatch(orderId){

let driversSnap = await getDocs(collection(db,"drivers"));

let nextDriver=null;

driversSnap.forEach(doc=>{
let d=doc.data();

// 🔥 driver online seulement
if(d.status==="online" && doc.id!==driverId && !nextDriver){
nextDriver={id:doc.id,...d};
}
});

if(!nextDriver){
await updateDoc(doc(db,"orders",orderId),{
status:"no_driver"
});
return;
}

// 🔥 NOUVELLE OFFER
await updateDoc(doc(db,"orders",orderId),{
offerDriverId:nextDriver.id,
offerExpiresAt:Date.now()+10000
});
}

// 🔥 ACTIONS
window.pick=async function(){
await updateDoc(doc(db,"orders",currentOrder.id),{status:"picked"});
}

window.deliver=async function(){

await updateDoc(doc(db,"orders",currentOrder.id),{status:"delivered"});

await updateDoc(doc(db,"drivers",driverId),{
status:"online",
currentOrderId:null
});
}

// 🔥 GPS LIVE
navigator.geolocation.watchPosition(async pos=>{

let lat=pos.coords.latitude;
let lng=pos.coords.longitude;

await updateDoc(doc(db,"drivers",driverId),{lat,lng});

if(!map){
map=L.map('map').setView([lat,lng],13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
driverMarker=L.marker([lat,lng]).addTo(map);
}else{
driverMarker.setLatLng([lat,lng]);
map.panTo([lat,lng]);
}

});

renderStatus();

</script>

</body>
</html>
